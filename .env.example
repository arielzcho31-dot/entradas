# ====================================
# VARIABLES DE ENTORNO - TICKETWISE
# ====================================
# IMPORTANTE: Este archivo es sensible. NO COMMITEAR.
# Copiar .env.example a .env.local y configurar valores reales

# ====================================
# POSTGRESQL DATABASE
# ====================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ticketwise_db
DATABASE_USER=postgres
DATABASE_PASSWORD=CAMBIAR_ESTA_CONTRASEÑA_EN_PRODUCCION

# O usar DATABASE_URL (alternativa):
# DATABASE_URL=postgresql://postgres:password@localhost:5432/ticketwise_db

# ====================================
# NEXT.JS
# ====================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:9004

# ====================================
# JWT/AUTH - CAMBIAR EN PRODUCCIÓN
# ====================================
JWT_SECRET=CAMBIAR_ESTE_SECRETO_JWT_EN_PRODUCCION_DEBE_SER_MUY_LARGO
REFRESH_TOKEN_SECRET=CAMBIAR_ESTE_SECRETO_REFRESH_EN_PRODUCCION_DEBE_SER_DIFERENTE

# ====================================
# EMAIL (Nodemailer)
# ====================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_email@gmail.com
EMAIL_PASSWORD=tu_app_password_gmail

# ====================================
# STORAGE (Local o S3)
# ====================================
UPLOAD_DIR=./uploads

# Para S3 en producción (opcional):
# AWS_BUCKET_NAME=tu-bucket
# AWS_REGION=us-east-1
